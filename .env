APP_NAME=payment-service
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
API_KEY=super-secret-api-key
DATABASE_URL=postgresql+asyncpg://payment:payment@postgres:5432/payments
ALEMBIC_DATABASE_URL=postgresql+psycopg://payment:payment@postgres:5432/payments
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
PAYMENTS_EXCHANGE=payments
PAYMENTS_NEW_QUEUE=payments.new
PAYMENTS_DLQ=payments.dlq
OUTBOX_PUBLISH_INTERVAL_SEC=1
WEBHOOK_TIMEOUT_SEC=5
MAX_WEBHOOK_ATTEMPTS=3
PAYMENT_PROCESSING_MIN_DELAY_SEC=2
PAYMENT_PROCESSING_MAX_DELAY_SEC=5
